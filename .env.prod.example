# =============================================================================
# Extravis Partner Portal — PRODUCTION environment
# Copy to .env.prod on the host (NEVER commit) and fill in real secrets.
# Generate strong values for all *_PASSWORD / *_SECRET / *_API_KEY fields.
# =============================================================================

# --- Database (used by both compose env_file substitution AND backend) ------
POSTGRES_USER=epp_app
POSTGRES_PASSWORD=__GENERATE_STRONG_RANDOM_24+_CHARS__
POSTGRES_DB=partner_portal

# DATABASE_URL is set inline in docker-compose.prod.yml from the values above
# (so we only have to type the password once). No need to set it here.

# --- JWT --------------------------------------------------------------------
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=__GENERATE_STRONG_RANDOM_48+_CHARS__
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS — restrict to production hostnames only --------------------------
CORS_ORIGINS=http://13.42.75.4:8088,https://partners.extravis.co

# --- Email (Office365 SMTP) -------------------------------------------------
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=__office365_mailbox__
SMTP_PASSWORD=__rotated_password__
SMTP_FROM_EMAIL=__office365_mailbox__
SMTP_FROM_NAME=Extravis Partner Portal
SMTP_TLS=true

# --- File storage / uploads -------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,image/png,image/jpeg

# --- Application ------------------------------------------------------------
APP_NAME=Extravis Partner Portal
APP_VERSION=1.0.0
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Frontend URL (used in email links) ------------------------------------
FRONTEND_URL=http://13.42.75.4:8088

# --- Bootstrap superadmin (created on first init only) ---------------------
SUPERADMIN_EMAIL=admin@extravis.com
SUPERADMIN_PASSWORD=__rotate_immediately_after_first_login__
SUPERADMIN_NAME=System Administrator

# --- Token expiry -----------------------------------------------------------
ACTIVATION_TOKEN_EXPIRE_HOURS=72
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# --- Rate limiting / lockout ------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

# --- Session ----------------------------------------------------------------
SESSION_TIMEOUT_HOURS=8

# --- AI / Groq (optional — leave blank to disable) -------------------------
AI_ENABLED=true
GROQ_API_KEY=__rotated_groq_key__
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_DEFAULT=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=20
AI_SCORE_CACHE_SECONDS=86400
